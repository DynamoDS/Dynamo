      "NodeType": "CodeBlockNode",
      "Code": "// Create control points for a periodic curve\npts = [\n    Point.ByCoordinates(0, 0, 0),\n    Point.ByCoordinates(10, 5, 0),\n    Point.ByCoordinates(20, 0, 0),\n    Point.ByCoordinates(20, -10, 0),\n    Point.ByCoordinates(10, -15, 0),\n    Point.ByCoordinates(0, -10, 0)\n];\ndegree = 3;",
      "Id": "codeblock1",
      "Inputs": [],
